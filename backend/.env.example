# App
NODE_ENV=production
PORT=3000
FRONTEND_URL=https://yourdomain.com

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_password
DB_DATABASE=updown_db

# JWT
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
JWT_EXPIRES_IN=7d

# Email (Nodemailer)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your@gmail.com
MAIL_PASS=your_app_password
MAIL_FROM="UpDown Platform <your@gmail.com>"
MAIL_ADMIN=iskovorodnikovs@gmail.com

# Telegram
MAIN_BOT_TOKEN=your_main_bot_token
MAIN_BOT_CHAT_ID=your_chat_id

# Verification codes
CODE_TTL_MINUTES=10

# Rate limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Broadcast rate limit (messages per second)
BROADCAST_RATE=25
